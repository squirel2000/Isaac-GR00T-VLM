+    i = _PHASE_ORDER.get(phase, 0)
+    grasped = i >= _PHASE_ORDER["grasp"]
+    placed = i >= _PHASE_ORDER["place"]
+    moving = _PHASE_ORDER["pick"] <= i < _PHASE_ORDER["place"]
+    phase_human = phase.replace("_", " ")
